<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Course Control Report</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap');
    @page {
      size: A4 landscape;
      margin: 0.5in;
    }
    body {
      font-family: Arial, "Helvetica Neue", Helvetica, sans-serif;
      font-size: 10.5pt;
      line-height: 1.1;
      color: #000;
      margin: 0;
      padding: 0;
    }
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }
    .logo {
      color: #1a56db;
      font-size: 24px;
      font-weight: bold;
      text-align: center;
      flex-grow: 1;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      page-break-inside: auto;
    }
    tr {
      page-break-inside: avoid;
      page-break-after: auto;
    }
    table td, table th {
      border: 0.5pt solid #000;
      padding: 3px 5px;
      vertical-align: middle;
    }
    th {
      font-weight: bold;
    }
    .text-center { text-align: center; }
    .bg-gray-200 { background-color: #e2e8f0; }
    .bg-gray-100 { background-color: #f1f5f9; }
  </style>
</head>
<body>

  <!-- Top Header Table -->
  <table>
    <tr>
      <td colspan="4" class="text-center" style="padding: 10px;">
        {{#if logoBase64}}
          <img src="{{logoBase64}}" style="height: 70px;" alt="Iqra University Logo">
        {{else}}
          <div style="background-color: #312e81; color: white; display: inline-block; padding: 10px 20px; font-size: 24px; font-weight: bold;">
             IQRA UNIVERSITY IU 
          </div>
        {{/if}}
      </td>
    </tr>
    <tr>
      <td colspan="4" class="text-center"><strong>Faculty of Engineering Sciences and Technology</strong></td>
    </tr>
    <tr>
      <td colspan="4" class="text-center"><strong>COURSE CONTROL REPORT</strong></td>
    </tr>
  </table>

  <!-- Course Info Table -->
  <table>
    <tr>
      <td style="width: 33%;"><strong>NAME OF FACULTY MEMBER</strong></td>
      <td style="width: 32%;" class="text-center">{{courseInfo.facultyName}}</td>
      <td style="width: 15%;"><strong>Session Days</strong></td>
      <td style="width: 20%;" class="text-center">{{courseInfo.sessionDay}}</td>
    </tr>
    <tr>
      <td><strong>PROGRAM</strong></td>
      <td class="text-center">{{courseInfo.program}}</td>
      <td><strong>Time Slot</strong></td>
      <td class="text-center">{{courseInfo.timeSlot}}</td>
    </tr>
    <tr>
      <td><strong>COURSE TITLE</strong></td>
      <td class="text-center">{{courseInfo.courseTitle}}</td>
      <td><strong>Location</strong></td>
      <td class="text-center">{{courseInfo.location}}</td>
    </tr>
    <tr>
      <td><strong>EDP CODE</strong></td>
      <td class="text-center">{{courseInfo.edpCode}}</td>
      <td><strong>Course Code</strong></td>
      <td class="text-center">{{courseInfo.courseCode}}</td>
    </tr>
  </table>

  <!-- Weekly Plan -->
  <table>
    <tr>
      <th style="width: 5%;" class="text-center">Week No.</th>
      <th style="width: 12%;" class="text-center">Schedule Date</th>
      <th style="width: 8%;" class="text-center">Time In</th>
      <th style="width: 8%;" class="text-center">Time Out</th>
      <th style="width: 32%;" class="text-center">Topic Covered</th>
      <th style="width: 8%;" class="text-center">*Q/A/CP/ MT/FE</th>
      <th style="width: 7%;" class="text-center">Duration</th>
      <th style="width: 10%;" class="text-center">Signature</th>
      <th style="width: 10%;" class="text-center">Remarks/ Comments</th>
    </tr>
    {{#each weeklyData}}
      {{#if this.isSpecialRow}}
        <tr class="bg-gray-200">
          <td class="text-center"><strong>{{this.weekNo}}</strong></td>
          <td colspan="4" class="text-center"><strong>{{this.specialRowText}}</strong></td>
          <td class="text-center"><strong>{{this.activityType}}</strong></td>
          <td colspan="3"></td>
        </tr>
      {{else}}
        <tr>
          {{#if this.showWeek}}
            <td rowspan="{{this.weekSpan}}" class="text-center"><strong>{{this.weekNo}}</strong></td>
          {{/if}}
          <td class="text-center">{{this.scheduleDate}}</td>
          <td class="text-center">{{this.timeIn}}</td>
          <td class="text-center">{{this.timeOut}}</td>
          <td>{{this.topicCovered}}</td>
          <td class="text-center">{{this.activityType}}</td>
          {{#if this.showDuration}}
            <td rowspan="{{this.durationSpan}}" class="text-center"><strong>{{this.duration}}</strong></td>
          {{/if}}
          <td class="text-center">{{this.signature}}</td>
          <td class="text-center">{{this.remarks}}</td>
        </tr>
      {{/if}}
    {{/each}}
  </table>

  <!-- Alternate Teacher / Makeup Class -->
  <table>
    <tr>
      <th colspan="9" class="text-center bg-gray-100"><strong>Alternate Teacher/ Makeup Class</strong></th>
    </tr>
    {{#each alternateData}}
      <tr>
        <td style="width: 5%;" class="text-center">{{this.rowNo}}</td>
        <td style="width: 12%;" class="text-center">{{this.scheduleDate}}</td>
        <td style="width: 8%;" class="text-center">{{this.timeIn}}</td>
        <td style="width: 8%;" class="text-center">{{this.timeOut}}</td>
        <td style="width: 32%;">{{this.topicCovered}}</td>
        <td style="width: 8%;" class="text-center">{{this.activityType}}</td>
        <td style="width: 7%;" class="text-center">{{this.duration}}</td>
        <td style="width: 10%;" class="text-center">{{this.signature}}</td>
        <td style="width: 10%;" class="text-center">{{this.remarks}}</td>
      </tr>
    {{/each}}
  </table>

</body>
</html>
